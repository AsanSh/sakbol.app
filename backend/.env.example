# ─── runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_ORIGIN=http://localhost:3001
PUBLIC_APP_URL=http://localhost:4200          # Flutter Web dev (или https://app.sakbol.app)
PUBLIC_LANDING_URL=http://localhost:4321      # Astro
CORS_ORIGINS=http://localhost:4321,http://localhost:4200

# ─── postgres (см. infra/docker-compose.yml: postgres на :5433 локально) ─
DATABASE_URL=postgresql://sakbol:sakbol_dev@localhost:5433/sakbol?schema=public

# ─── auth ─────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-long-random-string-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-different-from-access-secret-32-chars
JWT_REFRESH_TTL=30d

# HMAC-якорь ПИН/ИНН (КР). Минимум 32 случайных символа в production.
PIN_ANCHOR_PEPPER=change-me-to-long-random-string-min-32-chars

# ─── redis (очереди + rate limit) ─────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── MinIO (S3 API) ───────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_PRIVATE=sakbol-private
S3_BUCKET_PUBLIC=sakbol-public
S3_PUBLIC_URL_BASE=http://localhost:9000      # для генерации public-ссылок

# ─── Email: Resend (https://resend.com) ───────────────────────────────────
# В development оставьте пустым — StubEmailProvider пишет в лог.
RESEND_API_KEY=
EMAIL_FROM=noreply@sakbol.app
EMAIL_REPLY_TO=support@sakbol.app

# ─── SMS: Nikita Mobile (KG) ──────────────────────────────────────────────
# В development оставьте пустым — StubSmsProvider пишет код в лог.
NIKITA_LOGIN=
NIKITA_PASSWORD=
NIKITA_SENDER=SakBol

# ─── AI: Google Gemini ────────────────────────────────────────────────────
# Получить ключ: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro                   # ставим 3.1 Pro когда станет доступна
GEMINI_TIMEOUT_MS=60000

# ─── Sentry (опционально) ─────────────────────────────────────────────────
SENTRY_DSN=
